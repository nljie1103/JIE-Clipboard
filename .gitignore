# ==============================================
# JIE剪切板项目专用 Git 忽略文件
# 作用：自动屏蔽垃圾文件，只提交核心源码
# ==============================================

# 1. .NET / C# 编译产物（绝对不能推送）
bin/
obj/
x64/
x86/
publish/

# 2. Visual Studio 编辑器临时文件
.vs/
*.user
*.suo
*.sln.docstates
*.csproj.user

# 3. 系统自动生成的垃圾文件
Thumbs.db
Desktop.ini
*.tmp
*.cache
*.log

# 4. 项目无关的文本/临时文件
*.bak
*.old

# 5. 其他无用文件
*.pidb
*.svclog
*.resources